ONLINE_SSH_HTTP_PORT=8080
ONLINE_SSH_BIND_HOST=127.0.0.1
POSTGRES_DB=online_ssh
POSTGRES_USER=online_ssh
POSTGRES_PASSWORD=replace-with-strong-database-password
POSTGRES_DATA_DIR=./data/postgres
CREDENTIAL_MASTER_KEY=replace-with-32-bytes-or-longer-secret
SESSION_COOKIE_SECURE=false
ALLOW_USER_REGISTRATION=true
GOPROXY=https://proxy.golang.org,direct

# Optional: override the app DSN when POSTGRES_PASSWORD contains URL-reserved
# characters. Keep this value in sync with POSTGRES_DB/USER/PASSWORD.
# DATABASE_URL=postgres://online_ssh:replace-with-url-encoded-password@postgres:5432/online_ssh?sslmode=disable

# Optional: override the Go module proxy used while building the Docker image.
# GOPROXY=https://proxy.golang.org,direct

# Required by compose.production.yaml to prevent remote first-admin takeover on
# public fresh deployments. Local trial compose.yaml does not require it.
# BOOTSTRAP_SETUP_TOKEN=replace-with-one-time-setup-token

# For public production deployments, set this to false after the first admin is created
# unless open registration is intentional.
# ALLOW_USER_REGISTRATION=false
